@using static RaoVids.Components.InfoBox
@inject Services.ChannelService _channelService
@inject Services.InvokeScanService _invokeScanService
@inject Services.LogService _logService

@code {
    private const int DefaultMaxResults = 100;
    private const int DefaultPlayerRows = 1;
    private const int DefaultPlayerColumns = 1;
    private const int DefaultTitleSize = 1;

    [SupplyParameterFromForm]
    public string? channelIdToAdd { get; set; }

    private InfoBoxType _addChannelStatus = InfoBoxType.Info;
    private string? _addChannelMessage;

    private int _channelCount;
    private IEnumerable<Models.Channel> _allChannels = Enumerable.Empty<Models.Channel>();

    protected override async Task OnInitializedAsync()
    {
        _channelCount = await _channelService.GetChannelCountAsync();
        _allChannels = await _channelService.GetAllChannelsAsync();
    }

    private string FormatLastUpdated(DateTimeOffset dateTimeOffset)
    {
        if (dateTimeOffset.Year <= 1970)
        {
            return "Never";
        }
        else
        {
            return dateTimeOffset.ToLocalTime().ToString("g");
        }
    }

    private async Task SubmitAddChannel()
    {
        // Clear error/info status box.
        ClearStatus();

        // Sanitize input.
        var trimmedChannelId = channelIdToAdd?.Trim();

        if (trimmedChannelId == null || trimmedChannelId.Length == 0)
        {
            SetStatus(InfoBoxType.Error, "No channel ID or name specified");
            return;
        }

        // Add channel and catch any errors.
        try
        {
            await _channelService.AddChannelAsync(trimmedChannelId);
            _allChannels = await _channelService.GetAllChannelsAsync();
            SetStatus(InfoBoxType.Info, "Added channel " + trimmedChannelId);
        }
        catch (Exception ex)
        {
            SetStatus(InfoBoxType.Error, ex.Message);
        }

        // Force a channel rescan now.
        await ForceChannelRescan();
    }

    private async Task ForceChannelRescan()
    {
        await _logService.AddLogMessageAsync("Forcing channel rescan now");
        _invokeScanService.InvokeScan();
    }

    private void SetStatus(InfoBoxType type, string message)
    {
        _addChannelStatus = type;
        _addChannelMessage = message;
	}

    private void ClearStatus()
    {
        _addChannelStatus = InfoBoxType.Info;
        _addChannelMessage = null;
	}
}

<p>@_channelCount channel(s) registered</p>

<h2>Channels</h2>

<!-- Channels table -->
<table class="table">
  <thead>
    <tr>
      <th scope="col"></th>
      <th scope="col">Channel Name</th>
      <th scope="col">Last Updated</th>
      <th scope="col">Video Count</th>
    </tr>
  </thead>
  <tbody>
      @foreach (var channel in _allChannels)
      {
          <tr>
              <td><input type="checkbox" class="channel-checkbox" data-channel="@channel.ChannelName" /></td>
              <th scope="row" title="@channel.ChannelId">@channel.ChannelName</th>
              <td>@FormatLastUpdated(channel.LastUpdatedAt)</td>
              <td>@channel.VideoCount</td>
          </tr>
	}
  </tbody>
</table>

<script>
    function openViewer() {
        // Get max results from input.
        const maxResults = document.getElementById('maxResultsCount').value;
        const playerRows = document.getElementById('playerRows').value;
        const playerColumns = document.getElementById('playerColumns').value;
        const titleSize = document.getElementById('titleSize').value;

        // Get channels from checked boxes, a little trickier.
        let channels = [];

        const checkboxes = document.getElementsByClassName('channel-checkbox');
        for (let i = 0; i < checkboxes.length; ++i) {
            const checkbox = checkboxes[i];

            if (checkbox.checked) {
                channels.push(checkbox.dataset.channel);
            }
        }

        // Convert channels array to comma-separated string for passing in URL.
        const channelList = channels.join(',');

        // Log values for debugging.
        console.log('Opening viewer for channels ' + channelList + ' and results ' + maxResults);

        // Build URL.
        let url = `/viewer?count=${maxResults}`;

        if (channelList.length > 0) {
            url += `&channels=${channelList}`;
        }

        if (playerRows > 1) {
            url += `&rows=${playerRows}`;
        }

        if (playerColumns > 1) {
            url += `&columns=${playerColumns}`;
        }

        if (titleSize != 1) {
            url += `&titleSize=${titleSize}`;
        }

        // Redirect to url.
        window.location = url;
    }
</script>

<h2 style="margin-top: 1em">Play random videos</h2>
<form onsubmit="openViewer(); return false;">
    <table>
        <tr>
            <td><label>Video count: </label></td>
            <td><input type="number" id="maxResultsCount" Value="@DefaultMaxResults" /></td>
        </tr>
        <tr>
            <td><label>Title size: </label></td>
            <td><input type="number" step="0.1" id="titleSize" Value="@DefaultTitleSize" /></td>
        </tr>
        <tr>
            <td><label>Layout: </label></td>
            <td>
                <input type="number" id="playerRows" Value="@DefaultPlayerRows" />
                x
                <input type="number" id="playerColumns" Value="@DefaultPlayerColumns" />
            </td>
        </tr>
    </table>
    <br>
    <button type="submit">Open viewer</button>
</form>


<h2 style="margin-top: 1em">Add Channel</h2>
<InfoBox Message="@_addChannelMessage" Type="@_addChannelStatus" />

<form method="post" @onsubmit="SubmitAddChannel" @formname="add-channel-form">
    <AntiforgeryToken />
    <div>
        <label>Channel ID or Username: </label>
		<InputText @bind-Value="channelIdToAdd" />
        <button type="submit">Submit</button>
    </div>
</form>

<h2 style="margin-top: 1em">Force Rescan</h2>
<form method="post" @onsubmit="ForceChannelRescan" @formname="force-rescan-form">
    <AntiforgeryToken />
    <div>
        <label>Force a channel rescan now: </label>
        <button type="submit">Rescan</button>
    </div>
</form>

